# Discord Bot Configuration
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GUILD_ID=

# OAuth2 Callback URL
REDIRECT_URI=http://localhost:3000/callback

# Discord Channel IDs
CHANNEL_VERIFY=
CHANNEL_LOGS=

# Discord Role IDs
ROLE_MEMBER=
ROLE_ADMIN=

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/database

# Server
PORT=3000
CORS_ORIGIN=
TRUST_PROXY=false
LOG_FORMAT=

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# VPNAPI.io
VPNAPI_KEY=

# Verification Settings (optional)
PULLBACK_ONLY=false
CHECK_VPN=true
CHECK_FINGERPRINT=true
CHECK_IP_DUPLICATE=true
SESSION_TIMEOUT=300000

# Security Settings (optional)
MIN_ACCOUNT_AGE=7
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000
AUTO_KICK=true
AUTO_KICK_MAX_FAILURES=3
BLOCKED_COUNTRIES=
