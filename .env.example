# Discord Bot Configuration
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GUILD_ID=

# OAuth2 Callback URL (must be HTTPS in production)
REDIRECT_URI=http://localhost:3000/callback

# Discord Channel IDs
CHANNEL_VERIFY=
CHANNEL_LOGS=

# Discord Role IDs
ROLE_MEMBER=
ROLE_ADMIN=

# Database
DB_PATH=authbot.db

# Server
PORT=3000
CORS_ORIGIN=
TRUST_PROXY=false

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# VPNAPI.io VPN Detection (https://vpnapi.io)
VPNAPI_KEY=
